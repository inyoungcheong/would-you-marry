---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title?: string;
  author?: string;
  headings?: Heading[];
}

const {
  title = 'Would You Marry Superintelligence?',
  author = 'Inyoung Cheong',
  headings = [],
} = Astro.props;

const tocHeadings = headings.filter((h) => h.depth <= 3);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;0,600;1,400&family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <style>
      body {
        font-family: 'Lora', Georgia, 'Times New Roman', serif;
      }
      .ui-font {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      }

      /* Footnote styling */
      .prose .footnotes {
        border-top: 1px solid #e5e7eb;
        margin-top: 3rem;
        padding-top: 1.5rem;
      }
      .prose .footnotes h2 {
        font-size: 0.875rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: #6b7280;
        margin-bottom: 1rem;
        margin-top: 0;
      }
      .prose .footnotes ol {
        font-size: 0.875rem;
        color: #4b5563;
        line-height: 1.6;
      }
      .prose .footnotes li {
        margin-bottom: 0.5rem;
      }
      .prose a[data-footnote-ref] {
        font-size: 0.7rem;
        vertical-align: super;
        text-decoration: none;
        font-weight: 600;
        color: #2563eb;
        font-family: 'Inter', sans-serif;
      }
      .prose a[data-footnote-backref] {
        text-decoration: none;
        margin-left: 0.25rem;
      }

      /* Heading anchor links */
      .prose h2 > a,
      .prose h3 > a {
        color: inherit;
        text-decoration: none;
      }
      .prose h2 > a:hover::after,
      .prose h3 > a:hover::after {
        content: ' ¶';
        color: #9ca3af;
        font-weight: 400;
      }

      /* TOC */
      .toc-link {
        font-family: 'Inter', sans-serif;
        color: #9ca3af;
        transition: color 0.15s;
        line-height: 1.4;
      }
      .toc-link:hover {
        color: #374151;
      }
      .toc-link.active {
        color: #111827;
        font-weight: 500;
      }

      ::selection {
        background: #bfdbfe;
      }
    </style>
  </head>

  <body class="bg-white text-gray-900 antialiased">
    <!-- Top bar -->
    <header
      class="ui-font sticky top-0 z-50 border-b border-gray-100 bg-white/95 backdrop-blur-sm"
    >
      <div class="max-w-6xl mx-auto px-6 h-11 flex items-center">
        <span class="text-sm text-gray-400 truncate">{title}</span>
      </div>
    </header>

    <!-- Page body -->
    <div
      class="max-w-6xl mx-auto px-4 sm:px-6 py-10 lg:grid lg:gap-12"
      style="grid-template-columns: 210px 1fr;"
    >
      <!-- TOC sidebar -->
      <aside class="hidden lg:block">
        <nav id="toc" class="sticky top-20 max-h-[calc(100vh-6rem)] overflow-y-auto pr-2">
          <p class="ui-font text-xs font-semibold uppercase tracking-widest text-gray-400 mb-4">
            Contents
          </p>
          <ul class="space-y-1.5">
            {
              tocHeadings.map((h) => (
                <li class={h.depth === 3 ? 'pl-3' : ''}>
                  <a
                    href={`#${h.slug}`}
                    class={`toc-link block text-xs py-0.5 leading-snug`}
                    data-slug={h.slug}
                  >
                    {h.text}
                  </a>
                </li>
              ))
            }
          </ul>
        </nav>
      </aside>

      <!-- Article -->
      <article class="min-w-0 max-w-[700px]">
        <!-- Article header -->
        <header class="mb-10 pb-8 border-b border-gray-100">
          <h1 class="text-3xl font-bold text-gray-900 leading-tight mb-3">
            {title}
          </h1>
          <p class="ui-font text-sm text-gray-500">{author}</p>
        </header>

        <!-- Article body -->
        <div class="prose prose-lg">
          <slot />
        </div>
      </article>
    </div>

    <!-- Scroll-spy script -->
    <script>
      const headings = document.querySelectorAll('article h2[id], article h3[id]');
      const tocLinks = document.querySelectorAll<HTMLAnchorElement>('#toc .toc-link');

      if (headings.length && tocLinks.length) {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                tocLinks.forEach((l) => l.classList.remove('active'));
                const link = document.querySelector<HTMLAnchorElement>(
                  `#toc a[href="#${entry.target.id}"]`
                );
                link?.classList.add('active');
              }
            });
          },
          { rootMargin: '-15% 0px -70% 0px' }
        );
        headings.forEach((h) => observer.observe(h));
      }
    </script>
  </body>
</html>
