---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title?: string;
  author?: string;
  headings?: Heading[];
}

const {
  title = 'Would You Marry Superintelligence?',
  author = 'Inyoung Cheong',
  headings = [],
} = Astro.props;

const tocHeadings = headings.filter((h) => h.depth <= 3);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <script is:inline>
      // Password gate
      (function() {
        if (sessionStorage.getItem('auth') !== '1') {
          var pw = prompt('Password:');
          if (pw !== 'marry2026') {
            document.documentElement.innerHTML = '';
            location.href = 'about:blank';
          } else {
            sessionStorage.setItem('auth', '1');
          }
        }
      })();

      // Apply theme before paint to avoid flash
      (function() {
        var saved = localStorage.getItem('theme');
        var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (saved === 'dark' || (!saved && prefersDark)) {
          document.documentElement.classList.add('dark');
        } else {
          document.documentElement.classList.add('light');
        }
      })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,600;0,8..60,700;1,8..60,400&family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <style is:global>
      :root {
        --bg: #ffffff;
        --accent: #ee6d8a;
        --accent-mid: #ffa266;
        --border: #e5e7eb;
        --text: #1c1c1c;
        --text-muted: #6b7280;
        --header-bg: rgba(255,255,255,0.95);
        --footnote-text: #4b5563;
        --tooltip-bg: #fff;
        --tooltip-border: #e5e7eb;
        --tooltip-text: #374151;
      }

      html.dark {
        --bg: #18181b;
        --accent: #f08fa6;
        --accent-mid: #ffb380;
        --border: #2e2e35;
        --text: #e4e4e7;
        --text-muted: #9ca3af;
        --header-bg: rgba(24,24,27,0.95);
        --footnote-text: #a1a1aa;
        --tooltip-bg: #27272a;
        --tooltip-border: #3f3f46;
        --tooltip-text: #e4e4e7;
      }

      @media (prefers-color-scheme: dark) {
        html:not(.light) {
          --bg: #18181b;
          --accent: #f08fa6;
          --accent-mid: #ffb380;
          --border: #2e2e35;
          --text: #e4e4e7;
          --text-muted: #9ca3af;
          --header-bg: rgba(24,24,27,0.95);
          --footnote-text: #a1a1aa;
          --tooltip-bg: #27272a;
          --tooltip-border: #3f3f46;
          --tooltip-text: #e4e4e7;
        }
      }

      *,
      *::before,
      *::after {
        box-sizing: border-box;
      }

      html,
      body {
        max-width: 100vw;
        overflow-x: clip;
      }
      body {
        font-family: 'Source Serif 4', Georgia, 'Times New Roman', serif;
        background-color: var(--bg);
      }
      .ui-font {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      }

      /* Footnote section */
      .prose .footnotes {
        border-top: 1px solid var(--border);
        margin-top: 3rem;
        padding-top: 1.5rem;
      }
      .prose .footnotes h2 {
        font-size: 0.8rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: var(--text-muted);
        margin-bottom: 1rem;
        margin-top: 0;
        font-family: 'Inter', sans-serif;
      }
      .prose .footnotes ol {
        font-size: 0.84rem;
        color: var(--footnote-text);
        line-height: 1.65;
      }
      .prose .footnotes li {
        margin-bottom: 0.5rem;
      }

      /* Footnote ref superscript */
      .prose a[data-footnote-ref],
      .prose sup > a[href*='fn-'] {
        font-size: 0.68rem;
        vertical-align: super;
        text-decoration: none;
        font-weight: 700;
        color: var(--accent);
        font-family: 'Inter', sans-serif;
        cursor: pointer;
      }
      .prose a[data-footnote-backref] {
        text-decoration: none;
        margin-left: 0.25rem;
        color: var(--accent-mid);
      }

      /* Prose links */
      .prose a:not([data-footnote-ref]):not([data-footnote-backref]):not(h2 > a):not(h3 > a) {
        color: var(--accent);
        text-decoration: underline;
        text-decoration-color: rgba(238, 109, 138, 0.35);
      }
      .prose
        a:not([data-footnote-ref]):not([data-footnote-backref]):not(h2 > a):not(h3 > a):hover {
        text-decoration-color: var(--accent);
      }

      /* Heading anchor links — override all prose link styles */
      .prose h2 > a,
      .prose h3 > a {
        color: inherit !important;
        text-decoration: none !important;
        font-weight: inherit !important;
      }
      .prose h2 > a:hover::after,
      .prose h3 > a:hover::after {
        content: ' ¶';
        color: var(--border);
        font-weight: 400;
      }

      /* Desktop TOC */
      .toc-link {
        font-family: 'Inter', sans-serif;
        color: var(--text-muted);
        transition: color 0.15s;
        line-height: 1.4;
        text-decoration: none;
        display: block;
        padding-left: 8px;
        border-left: 2px solid transparent;
        transition:
          color 0.15s,
          border-color 0.15s;
      }
      .toc-link:hover {
        color: var(--text);
      }
      .toc-link.active {
        color: var(--accent);
        font-weight: 600;
        border-left-color: var(--accent);
      }

      /* Table overflow on mobile */
      .prose table {
        display: block;
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
        max-width: 100%;
      }

      /* Prevent any child from blowing out mobile width */
      article {
        min-width: 0;
        overflow-x: hidden;
      }

      /* Selection color */
      ::selection {
        background: rgba(238, 109, 138, 0.2);
      }

      /* ─── Reading progress bar ──────────────────────────────────── */
      #reading-progress {
        position: absolute;
        bottom: 0;
        left: 0;
        height: 2px;
        width: 0%;
        background: var(--accent);
        transition: width 0.07s linear;
        z-index: 10;
      }

      /* ─── Footnote tooltip ─────────────────────────────────────── */
      .fn-tooltip {
        position: fixed;
        z-index: 300;
        background: var(--tooltip-bg);
        border: 1px solid var(--tooltip-border);
        border-left: 3px solid var(--accent);
        border-radius: 6px;
        padding: 0.7rem 0.9rem;
        max-width: min(340px, calc(100vw - 2rem));
        font-size: 0.81rem;
        line-height: 1.65;
        color: var(--tooltip-text);
        box-shadow: 0 4px 18px rgba(0, 0, 0, 0.18);
        font-family: 'Inter', sans-serif;
        opacity: 1;
        transition: opacity 0.12s;
        pointer-events: none;
      }
      .fn-tooltip.hidden {
        opacity: 0;
        pointer-events: none;
      }

      /* ─── Mobile TOC drawer ───────────────────────────────────── */
      #mobile-toc-drawer {
        display: none;
        position: fixed;
        inset: 0;
        z-index: 200;
      }
      #mobile-toc-drawer.open {
        display: block;
      }
      #mobile-toc-overlay {
        position: absolute;
        inset: 0;
        background: rgba(0, 0, 0, 0.3);
      }
      #mobile-toc-panel {
        position: absolute;
        left: 0;
        top: 0;
        bottom: 0;
        width: min(270px, 82vw);
        background: var(--bg);
        padding: 1.5rem 1.25rem;
        overflow-y: auto;
        box-shadow: 4px 0 24px rgba(0, 0, 0, 0.12);
      }
      .mobile-toc-link {
        font-family: 'Inter', sans-serif;
        color: var(--text-muted);
        text-decoration: none;
        display: block;
        font-size: 0.875rem;
        padding: 0.2rem 0;
        line-height: 1.45;
      }
      .mobile-toc-link:hover {
        color: var(--accent);
      }

      /* ─── Dark mode prose overrides ─────────────────────────────── */
      html.dark .prose {
        --tw-prose-body: #e4e4e7;
        --tw-prose-headings: #f4f4f5;
        --tw-prose-bold: #f4f4f5;
        --tw-prose-quotes: #a1a1aa;
        --tw-prose-quote-borders: #3f3f46;
        --tw-prose-captions: #71717a;
        --tw-prose-code: #f4f4f5;
        --tw-prose-hr: #2e2e35;
        --tw-prose-links: #f08fa6;
      }
      @media (prefers-color-scheme: dark) {
        html:not(.light) .prose {
          --tw-prose-body: #e4e4e7;
          --tw-prose-headings: #f4f4f5;
          --tw-prose-bold: #f4f4f5;
          --tw-prose-quotes: #a1a1aa;
          --tw-prose-quote-borders: #3f3f46;
          --tw-prose-captions: #71717a;
          --tw-prose-code: #f4f4f5;
          --tw-prose-hr: #2e2e35;
          --tw-prose-links: #f08fa6;
        }
      }
    </style>
  </head>

  <body class="antialiased" style="color: var(--text);">
    <!-- ─── Top bar ─────────────────────────────────────────────── -->
    <header
      class="ui-font sticky top-0 z-50"
      style="position: sticky; border-bottom: 1px solid var(--border); background-color: var(--header-bg); backdrop-filter: blur(8px);"
    >
      <div class="max-w-5xl mx-auto px-4 sm:px-6 h-11 flex items-center gap-3">
        <!-- Hamburger — mobile only -->
        <button
          id="toc-toggle"
          class="lg:hidden shrink-0 flex flex-col justify-center gap-[5px] p-1 -ml-1"
          aria-label="Table of contents"
        >
          <span class="block w-[18px] h-[2px]" style="background: var(--text-muted);"></span>
          <span class="block w-[18px] h-[2px]" style="background: var(--text-muted);"></span>
          <span class="block w-[18px] h-[2px]" style="background: var(--text-muted);"></span>
        </button>
        <span class="text-sm truncate" style="color: var(--text-muted); flex: 1;">{title}</span>
        <!-- Dark mode toggle -->
        <button
          id="theme-toggle"
          aria-label="Toggle dark mode"
          style="shrink-0; padding: 4px; color: var(--text-muted); background: none; border: none; cursor: pointer; line-height: 1;"
        >
          <svg id="icon-moon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
          <svg id="icon-sun" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none;"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
        </button>
      </div>
      <!-- Reading progress bar -->
      <div id="reading-progress"></div>
    </header>

    <!-- ─── Mobile TOC drawer ──────────────────────────────────── -->
    <div id="mobile-toc-drawer" role="dialog" aria-modal="true" aria-label="Table of contents">
      <div id="mobile-toc-overlay"></div>
      <div id="mobile-toc-panel">
        <p
          class="ui-font text-xs font-semibold uppercase tracking-widest mb-4"
          style="color: var(--text-muted);"
        >
          Contents
        </p>
        <ul class="space-y-1">
          {
            tocHeadings.map((h) => (
              <li class={h.depth === 3 ? 'pl-3' : ''}>
                <a href={`#${h.slug}`} class="mobile-toc-link">
                  {h.text}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <!-- ─── Page body ──────────────────────────────────────────── -->
    <div
      class="max-w-5xl mx-auto px-4 sm:px-6 py-10 lg:grid lg:gap-12"
      style="grid-template-columns: 200px 1fr;"
    >
      <!-- TOC sidebar — desktop -->
      <aside class="hidden lg:block">
        <nav id="toc" class="sticky top-20 max-h-[calc(100vh-6rem)] overflow-y-auto pr-2">
          <p
            class="ui-font text-xs font-semibold uppercase tracking-widest mb-4"
            style="color: var(--text-muted);"
          >
            Contents
          </p>
          <ul class="space-y-1.5">
            {
              tocHeadings.map((h) => (
                <li class={h.depth === 3 ? 'pl-3' : ''}>
                  <a
                    href={`#${h.slug}`}
                    class="toc-link text-xs py-0.5 leading-snug"
                    data-slug={h.slug}
                  >
                    {h.text}
                  </a>
                </li>
              ))
            }
          </ul>
        </nav>
      </aside>

      <!-- Article -->
      <article class="min-w-0">
        <header class="mb-10 pb-8" style="border-bottom: 1px solid var(--border);">
          <h1 class="text-3xl font-bold leading-tight mb-3" style="color: var(--text);">
            {title}
          </h1>
          <p class="ui-font text-sm" style="color: var(--text-muted);">{author}</p>
        </header>

        <div class="prose prose-lg max-w-none">
          <slot />
        </div>
      </article>
    </div>

    <script>
      // ─── Dark mode ───────────────────────────────────────────────
      const html = document.documentElement;
      const moonIcon = document.getElementById('icon-moon')!;
      const sunIcon = document.getElementById('icon-sun')!;

      function applyTheme(dark: boolean) {
        if (dark) {
          html.classList.add('dark');
          html.classList.remove('light');
          moonIcon.style.display = 'none';
          sunIcon.style.display = 'block';
        } else {
          html.classList.remove('dark');
          html.classList.add('light');
          moonIcon.style.display = 'block';
          sunIcon.style.display = 'none';
        }
      }

      // Initialise from localStorage, falling back to system preference
      const saved = localStorage.getItem('theme');
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      applyTheme(saved === 'dark' || (!saved && prefersDark));

      document.getElementById('theme-toggle')!.addEventListener('click', () => {
        const isDark = html.classList.contains('dark');
        localStorage.setItem('theme', isDark ? 'light' : 'dark');
        applyTheme(!isDark);
      });

      // ─── Reading progress bar ────────────────────────────────────
      const progressBar = document.getElementById('reading-progress')!;
      function updateProgress() {
        const max = document.documentElement.scrollHeight - window.innerHeight;
        progressBar.style.width = (max > 0 ? (window.scrollY / max) * 100 : 0) + '%';
      }
      window.addEventListener('scroll', updateProgress, { passive: true });
      updateProgress();

      // ─── Scroll-spy (TOC active state) ──────────────────────────
      const headings = document.querySelectorAll('article h2[id], article h3[id]');
      const tocLinks = document.querySelectorAll<HTMLAnchorElement>('#toc .toc-link');

      if (headings.length && tocLinks.length) {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                tocLinks.forEach((l) => l.classList.remove('active'));
                const link = document.querySelector<HTMLAnchorElement>(
                  `#toc a[href="#${entry.target.id}"]`
                );
                link?.classList.add('active');
              }
            });
          },
          { rootMargin: '-10% 0px -75% 0px' }
        );
        headings.forEach((h) => observer.observe(h));
      }

      // ─── Mobile TOC drawer ───────────────────────────────────────
      const drawer = document.getElementById('mobile-toc-drawer')!;
      const overlay = document.getElementById('mobile-toc-overlay')!;
      const toggle = document.getElementById('toc-toggle')!;

      toggle.addEventListener('click', () => drawer.classList.toggle('open'));
      overlay.addEventListener('click', () => drawer.classList.remove('open'));
      drawer.querySelectorAll('.mobile-toc-link').forEach((link) => {
        link.addEventListener('click', () => drawer.classList.remove('open'));
      });

      // ─── Footnote tooltips ───────────────────────────────────────
      const fnTooltip = document.createElement('div');
      fnTooltip.className = 'fn-tooltip hidden';
      document.body.appendChild(fnTooltip);

      let hideTimer: ReturnType<typeof setTimeout>;

      // Build a map of all footnote texts keyed by every plausible fragment form
      const fnTextMap = new Map<string, string>();
      document.querySelectorAll<HTMLElement>('li[id]').forEach((li) => {
        const id = li.id;
        if (!id.includes('fn')) return; // only footnote list items
        const clone = li.cloneNode(true) as HTMLElement;
        clone.querySelectorAll('[data-footnote-backref], a[href*="fnref"]').forEach((el) =>
          el.remove()
        );
        const text = clone.textContent?.trim() ?? '';
        if (!text) return;
        // Store under original id, without user-content- prefix, and just the number
        fnTextMap.set(id, text);
        fnTextMap.set(id.replace(/^user-content-/, ''), text);
        const num = id.match(/\d+$/)?.[0];
        if (num) fnTextMap.set(num, text);
      });

      function getFootnoteText(href: string): string {
        const frag = href.replace(/^#/, '');
        if (fnTextMap.has(frag)) return fnTextMap.get(frag)!;
        const stripped = frag.replace(/^user-content-/, '');
        if (fnTextMap.has(stripped)) return fnTextMap.get(stripped)!;
        const num = frag.match(/\d+$/)?.[0];
        if (num && fnTextMap.has(num)) return fnTextMap.get(num)!;
        return '';
      }

      function positionTooltip(ref: HTMLElement) {
        const rect = ref.getBoundingClientRect();
        const tipW = Math.min(340, window.innerWidth - 32);
        let left = rect.left;
        if (left + tipW > window.innerWidth - 16) left = window.innerWidth - tipW - 16;
        if (left < 16) left = 16;
        fnTooltip.style.left = left + 'px';
        fnTooltip.style.top = rect.bottom + 8 + 'px';
        fnTooltip.style.maxWidth = tipW + 'px';
      }

      function showTooltip(ref: HTMLElement, text: string) {
        clearTimeout(hideTimer);
        fnTooltip.textContent = text;
        fnTooltip.classList.remove('hidden');
        positionTooltip(ref);
      }

      function hideTooltip() {
        fnTooltip.classList.add('hidden');
      }

      const isTouch = () => window.matchMedia('(hover: none)').matches;

      // Match footnote ref anchors — cast wide net
      const fnRefs = document.querySelectorAll<HTMLElement>(
        'sup a, a[data-footnote-ref]'
      );

      fnRefs.forEach((ref) => {
        const href = ref.getAttribute('href') ?? '';
        if (!href.includes('fn')) return;
        const text = getFootnoteText(href);
        if (!text) return;

        // Desktop hover
        ref.addEventListener('mouseenter', () => showTooltip(ref, text));
        ref.addEventListener('mouseleave', () => {
          hideTimer = setTimeout(hideTooltip, 300);
        });

        // Touch / mobile: tap toggles (prevent jumping to footnote)
        ref.addEventListener('click', (e) => {
          e.preventDefault();
          if (fnTooltip.classList.contains('hidden')) {
            showTooltip(ref, text);
          } else {
            hideTooltip();
          }
        });
      });

      document.addEventListener('click', (e) => {
        const t = e.target as HTMLElement;
        if (!t.closest('sup a') && !t.closest('a[data-footnote-ref]')) {
          hideTooltip();
        }
      });
    </script>
  </body>
</html>
