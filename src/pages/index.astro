---
import PaperLayout from '../layouts/PaperLayout.astro';
import Paper, { frontmatter, getHeadings } from '../paper.mdx';

const headings = getHeadings();
---

<PaperLayout title={frontmatter.title} author={frontmatter.author} posted={frontmatter.posted} lastUpdated={frontmatter.lastUpdated} pdfFile={frontmatter.pdfFile} password={frontmatter.password} headings={headings}>
  <Paper />
</PaperLayout>
